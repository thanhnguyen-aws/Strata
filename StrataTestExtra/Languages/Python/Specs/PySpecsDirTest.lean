    IO.FS.withTempDir fun outDir => do
      let r ← pySpecsDir testDir outDir dialectFile
        (modules := #["testpkg"])
        (warningOutput := .none)
        (pythonCmd := toString pythonCmd) |>.toBaseIO
      match r with
