-- ============================================================
-- Test: incremental - second run skips up-to-date files
-- ============================================================

private meta def testIncremental : IO Unit := withPython fun pythonCmd => do
  IO.FS.withTempFile fun _handle dialectFile => do
    IO.FS.writeBinFile dialectFile Strata.Python.Python.toIon
    IO.FS.withTempDir fun outDir => do
      -- First run
      match ← pySpecsDir testDir outDir dialectFile
        (modules := #["standalone"])
        (warningOutput := .none)
        (pythonCmd := toString pythonCmd) |>.toBaseIO with
      | .error msg => throw <| IO.userError s!"First run failed: {msg}"
      | .ok () => pure ()

      let outFile := outDir / "standalone.pyspec.st.ion"
      let .ok md1 ← outFile.metadata |>.toBaseIO
        | throw <| IO.userError "Output file missing after first run"
      let mtime1 := md1.modified

      -- Brief pause so filesystem timestamps differ
      IO.sleep 100

      -- Second run — should skip since output is newer
      match ← pySpecsDir testDir outDir dialectFile
        (modules := #["standalone"])
        (warningOutput := .none)
        (pythonCmd := toString pythonCmd) |>.toBaseIO with
      | .error msg => throw <| IO.userError s!"Second run failed: {msg}"
      | .ok () => pure ()

      let .ok md2 ← outFile.metadata |>.toBaseIO
        | throw <| IO.userError "Output file missing after second run"
      let mtime2 := md2.modified

      -- Timestamp should be unchanged (file was not rewritten)
      if mtime1 != mtime2 then
        throw <| IO.userError s!"Output was rewritten on second run (expected incremental skip)"

-- ============================================================
-- Test: error in one module doesn't prevent others
-- ============================================================

private meta def testContinueOnError : IO Unit := withPython fun pythonCmd => do
  IO.FS.withTempFile fun _handle dialectFile => do
    IO.FS.writeBinFile dialectFile Strata.Python.Python.toIon
    IO.FS.withTempDir fun outDir => do
      -- Translate both standalone (good) and broken (has duplicate class)
      let r ← pySpecsDir testDir outDir dialectFile
        (modules := #["standalone", "testpkg.broken"])
        (warningOutput := .none)
        (pythonCmd := toString pythonCmd) |>.toBaseIO
      -- Should fail (because broken module has an error)
      match r with
      | .ok () =>
        throw <| IO.userError "Expected failure due to broken module, but succeeded"
      | .error msg =>
        -- The good module should still have been translated
        if !(← fileExists (outDir / "standalone.pyspec.st.ion")) then
          throw <| IO.userError s!"standalone.pyspec.st.ion missing — error in broken module prevented other translations\nError: {msg}"
        -- Error message should mention the broken module
        if !(msg.splitOn "testpkg.broken").length != 1 then
          throw <| IO.userError s!"Error message doesn't mention testpkg.broken:\n{msg}"

-- ============================================================
-- Test: pySpecOutputPath
-- ============================================================

private meta def testOutputPath : IO Unit := do
  let check (src out file expected : String) : IO Unit := do
    match pySpecOutputPath src out file with
    | some p =>
      if p.toString != expected then
        throw <| IO.userError s!"pySpecOutputPath {src} {out} {file}: expected {expected}, got {p}"
    | none =>
      throw <| IO.userError s!"pySpecOutputPath {src} {out} {file}: expected {expected}, got none"
  check "inputs" "out" "inputs/foo.py" "out/foo.pyspec.st.ion"
  check "inputs" "out" "inputs/pkg/__init__.py" "out/pkg/__init__.pyspec.st.ion"
  check "inputs" "out" "inputs/pkg/mod.py" "out/pkg/mod.pyspec.st.ion"

-- ============================================================
-- Runner
-- ============================================================

private meta def runAllTests : IO Unit := do
  testOutputPath
  testFullDirectory
  testModuleFilter
  testModulePackage
  testSubdirRelativeImport
  testIncremental
  testContinueOnError

#guard_msgs in
#eval runAllTests

end Strata.Python.Specs.PySpecsDirTest
